# Auth backend
HOST=localhost
PORT=8080
PUBLIC_URL=http://localhost:8080

# Google OAuth client created in Google Cloud Console.
# Add this redirect URI to the Google OAuth client:
# http://localhost:8080/oauth/google/callback
GOOGLE_CLIENT_ID=replace-me.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace-me
GOOGLE_REDIRECT_URI=http://localhost:8080/oauth/google/callback

# Used to sign access tokens that the MCP server introspects.
# Use a long random value in real environments.
AUTH_JWT_SECRET=dev-change-me-to-a-long-random-string

# MCP resource this auth backend is allowed to issue tokens for.
MCP_RESOURCE=http://localhost:3000
